@model IEnumerable<HotelBookingManagement.Models.HoaDon>
@using HotelBookingManagement.Models
@{
    ViewData["Title"] = "Danh sách hóa đơn";
}

<h2>Danh sách hóa đơn</h2>

<table class="table table-bordered table-hover">

    <thead class="table-dark">
        <tr>
            <th>Mã HĐ</th>
            <th>Khách hàng</th>
            <th>Phòng</th>
            <th>Ngày lập</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th width="250">Thao tác</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Id</td>

                <td>
                    @item.DatPhong?.KhachHang?.HoTen
                </td>

                <td>
                    @item.DatPhong?.Phong?.TenPhong
                </td>

                <td>
                    @item.NgayLap.ToString("dd/MM/yyyy HH:mm")
                </td>

                <td>
                    @item.TongTien.ToString("N0") VNĐ
                </td>

                <td>
                    @if (item.TrangThai == TrangThaiHoaDon.DaThanhToan)
                    {
                        <span class="badge bg-success">
                            Đã thanh toán
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">
                            Chưa thanh toán
                        </span>
                    }
                </td>

                <td>

                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">
                        Chi tiết
                    </a>

                    @if (item.TrangThai == TrangThaiHoaDon.ChuaThanhToan)
                    {
                        <a asp-action="ThanhToan"
                           asp-route-id="@item.Id"
                           class="btn btn-success btn-sm">
                            Thanh toán
                        </a>
                    }

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Xóa
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>