@model IEnumerable<HotelBookingManagement.Models.Phong>

@{
    ViewData["Title"] = "Danh sách phòng";
}

<div class="container mt-4">

    <h2 class="mb-4">
        <i class="bi bi-building"></i> Danh sách phòng
    </h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-6">
            <form method="get">
                <div class="input-group">
                    <input type="text"
                           name="searchString"
                           value="@ViewBag.SearchString"
                           class="form-control"
                           placeholder="Nhập mã phòng hoặc tên phòng..." />

                    <button type="submit" class="btn btn-primary">
                        Tìm kiếm
                    </button>
                </div>
            </form>
        </div>

        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-success">
                Thêm phòng
            </a>
        </div>
    </div>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Mã phòng</th>
                <th>Tên phòng</th>
                <th>Tầng</th>
                <th>Giá phòng</th>
                <th>Loại phòng</th>
                <th>Trạng thái</th>
                <th width="220">Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaPhong</td>

                        <td>@item.TenPhong</td>

                        <td>@item.Tang</td>

                        <td>
                            @item.GiaPhong.ToString("N0") VNĐ
                        </td>

                        <td>
                            @item.LoaiPhong?.TenLoaiPhong
                        </td>

                        <td>
                            @switch (item.TrangThai)
                            {
                                case HotelBookingManagement.Models.TrangThaiPhong.Trong:
                                    <span class="badge bg-success">Trống</span>
                                    break;

                                case HotelBookingManagement.Models.TrangThaiPhong.DaDat:
                                    <span class="badge bg-warning text-dark">Đã đặt</span>
                                    break;

                                case HotelBookingManagement.Models.TrangThaiPhong.DangSuDung:
                                    <span class="badge bg-primary">Đang sử dụng</span>
                                    break;

                                case HotelBookingManagement.Models.TrangThaiPhong.DangDonDep:
                                    <span class="badge bg-info text-dark">Đang dọn dẹp</span>
                                    break;

                                case HotelBookingManagement.Models.TrangThaiPhong.BaoTri:
                                    <span class="badge bg-danger">Bảo trì</span>
                                    break;
                            }
                        </td>

                        <td>
                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm">
                                Chi tiết
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Sửa
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                                Xóa
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">
                        Không có dữ liệu
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>