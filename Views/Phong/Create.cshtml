@model HotelBookingManagement.Models.Phong

@{
    ViewData["Title"] = "Thêm phòng";
}

<h2>Thêm phòng</h2>

<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="MaPhong" class="form-label"></label>
                <input asp-for="MaPhong" class="form-control" />
                <span asp-validation-for="MaPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TenPhong" class="form-label"></label>
                <input asp-for="TenPhong" class="form-control" />
                <span asp-validation-for="TenPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SoPhong" class="form-label"></label>
                <input asp-for="SoPhong" class="form-control" />
                <span asp-validation-for="SoPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Tang" class="form-label"></label>
                <input asp-for="Tang" class="form-control" />
                <span asp-validation-for="Tang" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="GiaPhong" class="form-label"></label>
                <input asp-for="GiaPhong" class="form-control" />
                <span asp-validation-for="GiaPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LoaiPhongId" class="form-label">Loại phòng</label>
                <select asp-for="LoaiPhongId"
                        asp-items="ViewBag.LoaiPhongId"
                        class="form-select">
                    <option value="">-- Chọn loại phòng --</option>
                </select>
                <span asp-validation-for="LoaiPhongId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TrangThai" class="form-label"></label>
                <select asp-for="TrangThai"
                        asp-items="Html.GetEnumSelectList<HotelBookingManagement.Models.TrangThaiPhong>()"
                        class="form-select">
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="TienNghi" class="form-label"></label>
                <textarea asp-for="TienNghi" class="form-control"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="MoTa" class="form-label"></label>
                <textarea asp-for="MoTa" class="form-control"></textarea>
            </div>

            <button type="submit" class="btn btn-success">
                Lưu
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Quay lại
            </a>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}