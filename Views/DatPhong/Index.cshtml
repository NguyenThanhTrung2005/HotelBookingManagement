@model IEnumerable<HotelBookingManagement.Models.DatPhong>

@{
    ViewData["Title"] = "Danh sách đặt phòng";
}

<h2>Danh sách đặt phòng</h2>

<p>
    <a asp-action="Create" class="btn btn-success">
        Đặt phòng mới
    </a>
</p>

<table class="table table-bordered table-hover">

    <thead class="table-dark">
        <tr>
            <th>Khách hàng</th>
            <th>Phòng</th>
            <th>Ngày nhận</th>
            <th>Ngày trả</th>
            <th>Số người</th>
            <th>Trạng thái</th>
            <th width="300">Thao tác</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.KhachHang?.HoTen</td>

                <td>@item.Phong?.TenPhong</td>

                <td>@item.NgayNhanPhong.ToString("dd/MM/yyyy")</td>

                <td>@item.NgayTraPhong.ToString("dd/MM/yyyy")</td>

                <td>@item.SoNguoi</td>

                <td>@item.TrangThai</td>

                <td>

                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">
                        Chi tiết
                    </a>

                    <a asp-action="CheckIn"
                       asp-route-id="@item.Id"
                       class="btn btn-primary btn-sm">
                        Check-In
                    </a>

                    <a asp-action="CheckOut"
                       asp-route-id="@item.Id"
                       class="btn btn-success btn-sm">
                        Check-Out
                    </a>

                    <a asp-action="Cancel"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Hủy
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>