@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-4">

    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
        <div class="container-fluid py-4">
            <h1 class="display-5 fw-bold">Hệ thống quản lý đặt phòng khách sạn</h1>
            <p class="col-md-10 fs-5">
                Website hỗ trợ quản lý khách hàng, phòng khách sạn, đặt phòng,
                check-in, check-out, hóa đơn, thanh toán và thống kê doanh thu.
            </p>
            <a asp-controller="Phong" asp-action="Index" class="btn btn-primary btn-lg">
                Xem danh sách phòng
            </a>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Quản lý loại phòng</h5>
                    <p class="card-text">
                        Thêm, sửa, xóa và xem danh sách các loại phòng như phòng đơn,
                        phòng đôi, phòng gia đình hoặc phòng VIP.
                    </p>
                    <a asp-controller="LoaiPhong" asp-action="Index" class="btn btn-outline-primary">
                        Vào quản lý
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Quản lý phòng</h5>
                    <p class="card-text">
                        Quản lý thông tin phòng, giá phòng, tầng, tiện nghi,
                        mô tả và trạng thái phòng trong khách sạn.
                    </p>
                    <a asp-controller="Phong" asp-action="Index" class="btn btn-outline-primary">
                        Vào quản lý
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Quản lý khách hàng</h5>
                    <p class="card-text">
                        Lưu trữ thông tin khách hàng, số điện thoại, email,
                        căn cước công dân, địa chỉ và lịch sử đặt phòng.
                    </p>
                    <a asp-controller="KhachHang" asp-action="Index" class="btn btn-outline-primary">
                        Vào quản lý
                    </a>
                </div>
            </div>
        </div>

    </div>

    <div class="row g-4 mt-2">

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Đặt phòng</h5>
                    <p class="card-text">
                        Tạo phiếu đặt phòng trực tiếp hoặc đặt trước,
                        kiểm tra phòng trống và quản lý trạng thái đặt phòng.
                    </p>
                    <a asp-controller="DatPhong" asp-action="Index" class="btn btn-outline-success">
                        Vào quản lý
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Hóa đơn</h5>
                    <p class="card-text">
                        Tạo hóa đơn khi khách check-out, tính tiền phòng,
                        phụ thu và cập nhật trạng thái thanh toán.
                    </p>
                    <a asp-controller="HoaDon" asp-action="Index" class="btn btn-outline-success">
                        Vào quản lý
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Thống kê</h5>
                    <p class="card-text">
                        Theo dõi doanh thu, số lượng phòng trống,
                        phòng đã đặt, phòng đang sử dụng và phòng bảo trì.
                    </p>
                    <a asp-controller="ThongKe" asp-action="Index" class="btn btn-outline-success">
                        Vào thống kê
                    </a>
                </div>
            </div>
        </div>

    </div>

</div>