@model HotelBookingManagement.Models.LoaiPhong

@{
    ViewData["Title"] = "Xóa loại phòng";
}

<div class="container mt-4">

    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Xác nhận xóa loại phòng</h4>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                Bạn có chắc chắn muốn xóa loại phòng này không?
                Dữ liệu sẽ được chuyển sang trạng thái ngừng sử dụng thay vì xóa hoàn toàn.
            </div>

            <dl class="row">
                <dt class="col-sm-3">Tên loại phòng</dt>
                <dd class="col-sm-9">@Model.TenLoaiPhong</dd>

                <dt class="col-sm-3">Mô tả</dt>
                <dd class="col-sm-9">@Model.MoTa</dd>

                <dt class="col-sm-3">Số người tối đa</dt>
                <dd class="col-sm-9">@Model.SoNguoiToiDa</dd>

                <dt class="col-sm-3">Giá cơ bản</dt>
                <dd class="col-sm-9">@Model.GiaCoBan.ToString("N0") VNĐ</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        Hủy
                    </a>

                    <button type="submit" class="btn btn-danger">
                        Xác nhận xóa
                    </button>
                </div>
            </form>

        </div>
    </div>

</div>