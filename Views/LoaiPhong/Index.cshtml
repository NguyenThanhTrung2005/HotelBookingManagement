@model IEnumerable<HotelBookingManagement.Models.LoaiPhong>

@{
    ViewData["Title"] = "Danh sách loại phòng";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Danh sách loại phòng</h2>

        <a asp-action="Create" class="btn btn-primary">
            + Thêm loại phòng
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>STT</th>
                        <th>Tên loại phòng</th>
                        <th>Mô tả</th>
                        <th>Số người tối đa</th>
                        <th>Giá cơ bản</th>
                        <th style="width: 220px;">Chức năng</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int stt = 1;

                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@stt</td>
                                <td>@item.TenLoaiPhong</td>
                                <td>@item.MoTa</td>
                                <td>@item.SoNguoiToiDa</td>
                                <td>@item.GiaCoBan.ToString("N0") VNĐ</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                                        Chi tiết
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                        Sửa
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                        Xóa
                                    </a>
                                </td>
                            </tr>

                            stt++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                Chưa có loại phòng nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>